# AI Visibility Tracker — Environment Variables Template
# Copy to .env.local and fill in values as each account is provisioned.
# NEVER commit .env.local to git — it's in .gitignore by default in Next.js.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_PK_TEST=pk_test_
STRIPE_SK_TEST=sk_test_
STRIPE_PK_LIVE=pk_live_
STRIPE_SK_LIVE=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_STARTER_PRICE_ID=price_       # $39/mo Starter plan price ID
STRIPE_PRO_PRICE_ID=price_           # $89/mo Pro plan price ID

# ── Transactional Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_

# ── Dev helpers ───────────────────────────────────────────────────────────────
# Set to 1 locally to print emails to console instead of sending (avoids Resend quota in dev).
# ⚠️  DO NOT copy EMAIL_DRY_RUN to Vercel → Settings → Environment Variables → Production tab.
#    lib/email.ts returns { error } (not a fake ID) if this is set in NODE_ENV=production,
#    and /api/health/email returns HTTP 503 — so the misconfiguration is impossible to miss.
EMAIL_DRY_RUN=1

# ── AI Query APIs ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-
ANTHROPIC_API_KEY=sk-ant-
PERPLEXITY_API_KEY=pplx-

# ── SERP / Google AI Overviews ────────────────────────────────────────────────
SERPAPI_KEY=

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://aivistrack.com

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true AND ensure today >= 2026-06-17 to show real Stripe checkout on /pricing.
# When false (default): /pricing shows amber banner + "Notify me" waitlist form instead.
SUBSCRIPTIONS_LIVE=false
