# AI Visibility Tracker — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
# From https://app.supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # "anon public" key — safe for browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # service role — server only, KEEP SECRET

# ── Stripe ───────────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_   # publishable — safe for browser
STRIPE_SECRET_KEY=sk_test_                    # secret — server only, KEEP SECRET
STRIPE_WEBHOOK_SECRET=whsec_                  # from Stripe webhook endpoint settings
STRIPE_STARTER_PRICE_ID=price_               # $39/mo Starter plan price ID
STRIPE_PRO_PRICE_ID=price_                   # $89/mo Pro plan price ID

# ── Transactional Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_                            # from https://resend.com/api-keys

# ── Cron ─────────────────────────────────────────────────────────────────────
# Random secret to protect /api/cron/weekly — set same value in Vercel env + cron header
CRON_SECRET=                                  # e.g. openssl rand -hex 24

# ── Dev helpers ───────────────────────────────────────────────────────────────
# Set to 1 locally to print emails to console instead of sending via Resend.
# NEVER set this in Vercel Production env vars — lib/email.ts will log a loud
# startup error (🚨) if it detects EMAIL_DRY_RUN=1 under NODE_ENV=production.
EMAIL_DRY_RUN=1

# ── AI Query APIs ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-                            # GPT-4o for ChatGPT visibility checks
ANTHROPIC_API_KEY=sk-ant-                     # Claude for Claude visibility checks
PERPLEXITY_API_KEY=pplx-                      # Perplexity AI checks

# ── SERP / Google AI Overviews ────────────────────────────────────────────────
SERPAPI_KEY=                                  # from https://serpapi.com

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000     # prod: https://neuralreach.de

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true AND ensure today >= 2026-06-04 to show real Stripe checkout on /pricing.
# When false (default): /pricing shows amber banner + "Notify me" waitlist form instead.
SUBSCRIPTIONS_LIVE=false
