# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local.from-workspace-root

# local dev data (may contain emails)
data/waitlist-local.json

# HAR / browser session captures — may contain auth tokens
*.har

# Python bytecode and scorer LLM-response cache
**/__pycache__/
scorer/.cache/
